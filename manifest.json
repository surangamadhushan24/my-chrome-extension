{
  "manifest_version": 3,
  "name": "Website Blocker (Personal)",
  "version": "1.0",
  "description": "Blocks Facebook and YouTube",
  "background": {
    "service_worker": "background.js"
  },
  "permissions": ["declarativeNetRequest"],
  "host_permissions": ["*://*.facebook.com/*", "*://*.youtube.com/*"],
  "declarative_net_request": {
    "rule_resources": [
      {
        "id": "ruleset_1",
        "enabled": true,
        "path": "rules.json"
      }
    ]
  }
}
